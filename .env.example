# API runtime
QADAM_ENVIRONMENT=development
QADAM_ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
QADAM_LEGAL_CORPUS_PATH=./corpus/legal

# Persistence
QADAM_DATABASE_URL=postgresql+psycopg://qadam:qadam@localhost:5432/qadam

# Optional OpenAI-compatible explanation provider.
# Leave any of these blank to keep the deterministic offline provider.
QADAM_LLM_BASE_URL=
QADAM_LLM_MODEL=
QADAM_LLM_API_KEY=

# Browser build-time API URL
NEXT_PUBLIC_API_URL=http://localhost:8000
